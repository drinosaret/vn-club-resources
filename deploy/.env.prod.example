# ===========================================
# VN Club Production Environment
# ===========================================
# Copy to .env.prod and fill in all values.
# Used by: docker compose -f docker-compose.prod.yml --env-file deploy/.env.prod up -d

# ===========================================
# Database
# ===========================================
# Generate a strong password: openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME

# ===========================================
# Frontend URLs (baked into Next.js at build time)
# ===========================================
NEXT_PUBLIC_VNDB_STATS_API=https://api.vnclub.org
NEXT_PUBLIC_API_URL=https://api.vnclub.org

# ===========================================
# VNDB API (optional — for user list lookups)
# ===========================================
VNDB_API_TOKEN=

# ===========================================
# Discord Bot
# ===========================================
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
# Comma-separated user IDs allowed to execute Ichijou commands
DISCORD_ADMIN_USER_IDS=

# ===========================================
# CORS
# ===========================================
CORS_ORIGINS=["https://vnclub.org"]

# ===========================================
# Cloudflare Turnstile (bot protection for share links)
# ===========================================
# Create a widget at: Cloudflare dashboard > Turnstile > Add widget
# Widget type: Invisible
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ===========================================
# Shared Secrets
# ===========================================
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=
BLACKLIST_REFRESH_SECRET=

# ===========================================
# Redis
# ===========================================
# Generate with: openssl rand -hex 32
REDIS_PASSWORD=CHANGE_ME

# ===========================================
# Twitter/X (optional — for news aggregation)
# ===========================================
TWITTER_AUTH_TOKEN=

# ===========================================
# Umami Analytics
# ===========================================
# Generate with: openssl rand -hex 32
UMAMI_DB_PASSWORD=CHANGE_ME
UMAMI_APP_SECRET=CHANGE_ME
# Frontend URL and website ID (baked into Next.js at build time)
NEXT_PUBLIC_UMAMI_URL=https://analytics.vnclub.org
# Get this from Umami dashboard after first login: Settings > Websites > vnclub.org
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
